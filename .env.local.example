# Supabase — aus Supabase Dashboard → Settings → API kopieren
# In Vite müssen alle Client-zugänglichen Vars mit VITE_ prefixed sein.

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=ey...

# Single-User-Lock — nur diese E-Mail darf einloggen.
VITE_ADMIN_EMAIL=luisfederolf@googlemail.com

# Optional: vorausgefüllte E-Mail im Login-Form
VITE_DEFAULT_LOGIN_EMAIL=luisfederolf@googlemail.com

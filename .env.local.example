# Supabase — aus Project Settings → API kopieren
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Service-Role-Key (NIE in den Client). Wird für Seed-Skripte und Server-Actions
# mit erweiterten Rechten genutzt.
SUPABASE_SERVICE_ROLE_KEY=ey...

# Single-User-Lock — nur diese E-Mail darf einloggen.
ADMIN_EMAIL=luisfederolf@googlemail.com

# Optional: vorausgefüllte E-Mail im Login-Form (nur lokal)
NEXT_PUBLIC_DEFAULT_LOGIN_EMAIL=luisfederolf@googlemail.com
